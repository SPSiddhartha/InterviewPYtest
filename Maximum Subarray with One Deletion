def maximumSum(arr):
    n = len(arr)
    forward = arr[:]
    backward = arr[:]

    for i in range(1, n):
        forward[i] = max(arr[i], forward[i-1] + arr[i])

    for i in range(n-2, -1, -1):
        backward[i] = max(arr[i], backward[i+1] + arr[i])

    result = max(forward)
    for i in range(1, n-1):
        result = max(result, forward[i-1] + backward[i+1])

    return result

