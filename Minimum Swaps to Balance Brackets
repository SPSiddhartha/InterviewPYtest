Minimum Swaps to Balance Brackets

Concept: Greedy / Counting imbalance
Example:
Input: "][]["
Output: 1

def minSwaps(s: str) -> int:
    imbalance = 0
    open_count = 0

    for char in s:
        if char == '[':
            open_count += 1
        else:
            if open_count > 0:
                open_count -= 1
            else:
                imbalance += 1

    return (imbalance + 1) // 2

